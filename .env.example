# Omni-Bridge Core Orchestrator — env example for local development
# Copy this to .env and fill in values. Never commit .env to Git.

# GCP project (already set in config.py defaults — override here if needed)
GCP_PROJECT_ID=prompt-wars-bengaluru-2026
GCP_LOCATION=us-central1

# Vertex AI models (defaults shown)
TRIAGE_MODEL=gemini-2.0-flash-001
SYNTHESIS_MODEL=gemini-2.0-flash-001

# Pub/Sub
PUBSUB_TOPIC_HITL=omnibridge-hitl-queue

# Local dev: point to your GCP service account JSON key for ADC
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-sa-key.json
